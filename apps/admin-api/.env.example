# Admin API runtime
NODE_ENV=production
PORT=3001
TRUST_PROXY=true

# PostgreSQL
DATABASE_URL=postgresql://user:password@your-db-host.region-postgres.render.com/dbname
PGSSLMODE=require

# JWT session/cookies
AUTH_JWT_SECRET=replace-with-long-random-secret
COOKIE_NAME=admin_session
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
SESSION_TTL_HOURS=12

# CORS for browser frontend (comma-separated origins, no path)
CORS_ALLOWED_ORIGINS=https://akcd1998.github.io
CORS_ALLOW_ALL=false

# Feature flags
FEATURE_STOCK_REQUESTS=false

# Auth allowlists and bcrypt hashes
ADMIN_USERS=admin@example.com
STAFF_USERS=staff@example.com
ADMIN_PASSWORD_HASH=
STAFF_PASSWORD_HASH=
BRANCH_USERS=branch001@example.com
BRANCH_USER_BRANCHES=branch001@example.com:001
BRANCH_USER_PASSWORD_HASHES=branch001@example.com:$2b$10$replace.with.branch.user.hash
POS_API_KEYS=

# Future mother-PC agent reference only. Do not commit real credentials.
ADAPOS_SQLSERVER_HOST=mother-pc-or-sql-host
ADAPOS_SQLSERVER_PORT=1433
ADAPOS_SQLSERVER_USER=readonly_user
ADAPOS_SQLSERVER_PASSWORD=change_me
ADAPOS_SQLSERVER_DATABASE=AdaAcc
ADAPOS_SYNC_INTERVAL_MINUTES=10
ADAPOS_SYNC_DRY_RUN=true
ADAPOS_SYNC_DRIVER=simulation
ADAPOS_SYNC_DATASETS=branches,products,transfers,branch-stock
ADAPOS_SYNC_BRANCH_CODE=
ADAPOS_SYNC_WATERMARK_FILE=./scripts/.ada_sync_watermarks.json
ADAPOS_SYNC_FIXTURE_PATH=./scripts/fixtures/ada_sync_simulation.json
ADAPOS_SYNC_API_BASE_URL=http://localhost:3001

# Rate limiting + upload
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
MAX_UPLOAD_MB=25
DEFAULT_PERIOD_DAYS=30

# Embeddings / Hybrid Search
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_TIMEOUT_MS=30000
# OPENAI_API_KEY=replace-with-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# EMBEDDING_LOCAL_URL=http://localhost:11434/v1/embeddings
